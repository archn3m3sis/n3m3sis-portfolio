{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
	"enabled": true,
	"clientKind": "git",
	"useIgnoreFile": true
  },
  "files": {
	"ignoreUnknown": false,
	"includes": [
	  "**/*.ts",
	  "**/*.tsx",
	  "**/*.js",
	  "**/*.jsx",
	  "**/*.mjs",
	  "**/*.cjs",
	  "**/*.json",
	  "**/*.jsonc",
	  "**/*.css",
	  "!**/.next",
	  "!**/node_modules",
	  "!**/.velite",
	  "!**/.vercel",
	  "!**/result",
	  "!**/result-*",
	  "!**/dist",
	  "!**/build",
	  "!next-env.d.ts",
	  "!pnpm-lock.yaml"
	]
  },
  "formatter": {
	"enabled": true,
	"indentStyle": "space",
	"indentWidth": 2,
	"lineWidth": 100,
	"lineEnding": "lf"
  },
  "javascript": {
	"formatter": {
	  "quoteStyle": "double",
	  "jsxQuoteStyle": "double",
	  "semicolons": "always",
	  "trailingCommas": "all",
	  "bracketSpacing": true,
	  "bracketSameLine": false,
	  "arrowParentheses": "always"
	}
  },
  "linter": {
	"enabled": true,
	"rules": {
	  "recommended": true,
	  "style": {
		"noNonNullAssertion": "warn",
		"useConst": "error",
		"useTemplate": "error"
	  },
	  "suspicious": {
		"noExplicitAny": "warn",
		"noConsole": {
		  "level": "warn",
		  "options": {
			"allow": ["warn", "error"]
		  }
		}
	  },
	  "correctness": {
		"noUnusedVariables": "warn",
		"noUnusedImports": "error",
		"useExhaustiveDependencies": "warn"
	  },
	  "nursery": {
		"useSortedClasses": {
		  "level": "warn",
		  "options": {
			"attributes": ["className"],
			"functions": ["cn", "clsx", "cva", "tw"]
		  }
		}
	  }
	}
  },
  "css": {
	"formatter": {
	  "enabled": true,
	  "indentStyle": "space",
	  "indentWidth": 2,
	  "lineWidth": 100
	}
  },
  "json": {
	"formatter": {
	  "enabled": true,
	  "indentStyle": "space",
	  "indentWidth": 2,
	  "trailingCommas": "none"
	}
  },
  "assist": {
	"enabled": true,
	"actions": {
	  "source": {
		"organizeImports": "on"
	  }
	}
  },
  "overrides": [
	{
	  "includes": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
	  "linter": {
		"rules": {
		  "suspicious": {
			"noExplicitAny": "off",
			"noConsole": "off"
		  }
		}
	  }
	}
  ]
}