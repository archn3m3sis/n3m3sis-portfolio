# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
# even though originally genrated gitignore created by the next js application by default we 
# will need to create a specified gitignore so that our .env.exanple file does not get ignored...
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# velite -- generated content output 
.velite/

# nix -- build outputs and direnv cache 
result
result-*
.direnv/

# editor/IDE directories 
.nova
.idea/
.vscode/
