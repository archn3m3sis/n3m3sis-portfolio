# ============================================================
# Environment Variables — .env.example
#
# Copy this file to .env.local for local dev, or .env on the
# server for production. Both .env and .env.local are gitignored.
#
# NEXT_PUBLIC_* prefixed vars are exposed to the browser.
# All others are server-only and must never reach client bundles.
# ============================================================


# ---------- Site ----------
# The canonical URL where the site is served.
NEXT_PUBLIC_SITE_URL=https://www.archn3m3sis.com


# ---------- Email (Resend) ----------
# Create an API key at https://resend.com/api-keys
# Required for the contact form.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The address where contact form submissions are delivered.
CONTACT_TO_EMAIL=hello@archn3m3sis.com


# ---------- Bot Protection (Cloudflare Turnstile) ----------
# Create a site at https://dash.cloudflare.com/?to=/:account/turnstile
# Both keys required for the contact form's invisible CAPTCHA.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0xxxxxxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0xxxxxxxxxxxxxxxxxxxxx


# ---------- Rate Limiting (Upstash Redis) ----------
# Create a Redis database at https://console.upstash.com/
# Required to rate-limit contact form submissions.
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ---------- GitHub API (pinned repos showcase) ----------
# Create a fine-grained token at
# https://github.com/settings/personal-access-tokens/new
# Scopes: read:user (public repo metadata only)
# Required to display pinned repos on the Projects page.
GITHUB_API_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub username — used in pinned repo queries.
GITHUB_USERNAME=archn3m3sis


# ---------- Sentry (Error Tracking) ----------
# Create a project at https://sentry.io/
# Optional — site runs fine without it.
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxx@xxxx.ingest.sentry.io/xxxxxxxx


# ---------- Cal.com (Meeting Booking) ----------
# Your Cal.com public booking path (e.g. "archn3m3sis/intro-call").
# Used by the embedded booking widget on the contact page.
NEXT_PUBLIC_CAL_LINK=archn3m3sis/intro-call